# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.atylas.mongodb.net/certificate_generator
MONGODB_DB_NAME=certificate_generator

# File Storage Configuration
CERTIFICATE_STORAGE_PATH=./certificates
MAX_FILE_SIZE_MB=10

# Security Configuration
JWT_SECRET=your-secret-key-change-in-production
CERTIFICATE_SECRET_KEY=change-this-certificate-hmac-secret
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
